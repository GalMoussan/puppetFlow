# Database (Supabase)
# App runtime: use pooled URL (port 6543 + pgbouncer)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
# Migrations: use direct URL (port 5432) when pooler is enabled
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# LLM provider: auto | anthropic | deepseek
# auto = DeepSeek if only DEEPSEEK_API_KEY is set, else Anthropic if present
LLM_PROVIDER="auto"

# Anthropic (Claude) — optional
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# DeepSeek — use this alone for testing if you have no Anthropic key
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-chat"

# Basic Authentication (Phase 5 — required in production)
# Browser will prompt; Playwright uses these via httpCredentials.
APP_USER="admin"
APP_PASSWORD="your-secure-password"

# Set to true only for local debugging without the login prompt
# DISABLE_BASIC_AUTH="true"

# Runtime
NODE_ENV="development"
